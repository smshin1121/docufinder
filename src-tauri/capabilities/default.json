{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "DocuFinder default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
