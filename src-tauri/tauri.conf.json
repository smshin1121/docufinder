{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anything",
  "version": "2.6.2",
  "identifier": "com.anything.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Anything",
        "visible": false,
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' https://github.com https://objects.githubusercontent.com https://api.github.com; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/node.exe",
      "resources/kordoc/**/*",
      "resources/paddleocr/det.onnx",
      "resources/paddleocr/rec.onnx",
      "resources/paddleocr/dict.txt",
      "resources/onnxruntime/onnxruntime.dll",
      "icons/tray-icon.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/chrisryugj/Docufinder/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEOENFMzc4MzE5OERERjEKUldUeDNaZ3hlT09NL1JqS0p5UHM5MURpRE5kK0xRVXpnRkg3Ums1c0JBTUN1LzkwNDhQYTY1VW0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
