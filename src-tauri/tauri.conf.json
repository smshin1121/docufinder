{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anything",
  "version": "0.1.0",
  "identifier": "com.anything.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Anything",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: asset: https://asset.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "models/multilingual-e5-small/*": "models/multilingual-e5-small/"
    },
    "windows": {
      "wix": {
        "language": "ko-KR"
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGQTIzNUZDMUE5MERDRTcKUldUbjNKQWEvRFdpbi9VU2RrVzUvY2JFZG1MTTc5SzlhN25iSW9sQlhkT2piYWkvUFIyR0QwSnQK",
      "endpoints": [
        "https://github.com/chrisryugj/Docufinder/releases/latest/download/latest.json"
      ]
    }
  }
}