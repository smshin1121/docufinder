{
  "name": "promo-video",
  "version": "1.0.0",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts IntroVideo out/video.mp4",
    "build:prologue": "remotion render src/index.ts Prologue out/prologue.mp4 --codec=h264 --crf=18",
    "build:prologue:gif": "remotion render src/index.ts Prologue out/prologue.gif --codec=gif --width=1280 --height=720",
    "build:prologue:webm": "remotion render src/index.ts Prologue out/prologue.webm --codec=vp9 --crf=30"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.252",
    "@remotion/google-fonts": "4.0.252"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.252",
    "@types/react": "^18.2.0",
    "typescript": "^5.2.2"
  }
}
